# Chronos — configuration. Copy to .env.local and fill in what you need.
# AI keys below are server-only. The Supabase NEXT_PUBLIC_* values are the one
# exception (public by design — RLS does the per-user protection).

# Which extractor reads your Life Conversation into candidate events.
# Optional override: 'claude' | 'gemini' | 'ollama' | 'stub'. When unset, Chronos
# auto-picks: an Anthropic key → Claude; else a Gemini key → Gemini; else an
# Ollama model → local Ollama; else the deterministic stub (dev/test only —
# parses "HH:MM-HH:MM What happened").
CHRONOS_EXTRACTOR=

# Per-user daily cap on captures (each capture calls a model). Guards cost and
# the shared free-tier quota on a public deployment. Default 50; raise/lower to
# taste. For a low-cost public launch, pin CHRONOS_EXTRACTOR=gemini (free tier)
# and keep this cap on.
CHRONOS_DAILY_CAPTURE_LIMIT=50

# --- Option A: Claude (cloud, paid) ---
# Anthropic API key. Needed only when using Claude.
ANTHROPIC_API_KEY=
# Extraction model (CLAUDE.md §8: default Claude Sonnet 5, swappable).
CHRONOS_EXTRACTION_MODEL=claude-sonnet-5

# --- Option B: Google Gemini (cloud, free tier) ---
# Get a key at https://aistudio.google.com/apikey, then set CHRONOS_EXTRACTOR=gemini.
GEMINI_API_KEY=
# CHRONOS_GEMINI_MODEL=gemini-2.5-flash   # optional model override (default)

# --- Option C: Ollama (local, free, private — nothing leaves your machine) ---
# Install Ollama, then: ollama pull qwen2.5:14b
# Set CHRONOS_EXTRACTOR=ollama (or leave the other keys blank).
CHRONOS_OLLAMA_MODEL=qwen2.5:14b
# Override only if the Ollama daemon is not on the default local port.
OLLAMA_HOST=http://localhost:11434

# --- Error monitoring (optional) ---
# Set to your Sentry DSN to turn on error reporting (server + browser). Unset =
# no Sentry, no behavior change. Reports never include narratives or PII by
# design. For source-map upload on deploy, also run `npx @sentry/wizard@latest
# -i nextjs` once (adds the build plugin) and set SENTRY_AUTH_TOKEN in CI.
NEXT_PUBLIC_SENTRY_DSN=

# --- Accounts + backend (optional) ---
# Set BOTH to turn on Google sign-in + per-user Supabase persistence (RLS
# isolates each account). Leave BOTH unset to run in single-user, file-backed
# local mode with no login. See the README "Accounts & backend" section for the
# Google OAuth setup steps. Runtime uses only the anon/publishable key — no
# service-role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chronos v0 — server-side configuration. Copy to .env.local and fill in.
# All values are server-only; never expose them with a NEXT_PUBLIC_ prefix.

# Which extractor reads your Life Conversation into candidate events.
# Optional override: 'ollama' | 'claude' | 'stub'. When unset, Chronos auto-
# picks: an Anthropic key → Claude; else an Ollama model → local Ollama; else
# the deterministic stub (dev/test only — parses "HH:MM-HH:MM What happened").
CHRONOS_EXTRACTOR=

# --- Option A: Claude (cloud) ---
# Anthropic API key. Needed only when using Claude.
ANTHROPIC_API_KEY=
# Extraction model (CLAUDE.md §8: default Claude Sonnet 5, swappable).
CHRONOS_EXTRACTION_MODEL=claude-sonnet-5

# --- Option B: Ollama (local, free, private — nothing leaves your machine) ---
# Install Ollama, then: ollama pull qwen2.5:14b
# Set CHRONOS_EXTRACTOR=ollama (or leave the Anthropic key blank).
CHRONOS_OLLAMA_MODEL=qwen2.5:14b
# Override only if the Ollama daemon is not on the default local port.
OLLAMA_HOST=http://localhost:11434

# Supabase (Phase 3+; leave empty until provisioned)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
